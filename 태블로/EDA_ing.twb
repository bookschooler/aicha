      <aliases enabled='yes' />
      <column caption='1분기 평균 매출' datatype='real' name='[1분기_평균]' role='measure' type='quantitative' />
      <column caption='2분기 평균 매출' datatype='real' name='[2분기_평균]' role='measure' type='quantitative' />
      <column caption='3개년 총평균 매출' datatype='real' name='[3개년_총평균]' role='measure' type='quantitative' />
