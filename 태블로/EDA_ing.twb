      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0tgjy820av4rzl1exxcpm08uj2yn].[usr:Calculation_2396429261922304:qk:1]&quot;' value='공급갭지수_Rank' />
          <alias key='&quot;[federated.0tgjy820av4rzl1exxcpm08uj2yn].[usr:Calculation_2396429268557828:qk:1]&quot;' value='당월 매출액_랭킹' />
        </aliases>
      </column>
      <column caption='Adstrd Cd' datatype='string' name='[ADSTRD_CD]' role='dimension' type='nominal' />
      <column caption='Adstrd Name' datatype='string' name='[ADSTRD_CD_]' role='dimension' type='nominal' />
      <column caption='공급갭 지수_rank' datatype='integer' default-format='N' name='[Calculation_2396429261922304]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(AVG([공급갭_지수]), &apos;ASC&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='c. 랭킹 기준 선택' datatype='real' name='[Calculation_2396429268041731]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[매개 변수 2]&#13;&#10;WHEN &quot;당월 매출액&quot; THEN [당월_매출_금액]&#13;&#10;WHEN &quot;공급갭 지수&quot; THEN [공급갭_지수]&#13;&#10;END' />
      </column>
      <column caption='c. 랭킹 매기기' datatype='integer' name='[Calculation_2396429268557828]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(AVG([Calculation_2396429268041731]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='당월_매출_log' datatype='real' name='[Calculation_2701818593087488]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOG([당월_매출_금액])' />
      </column>
      <column caption='매출_구간' datatype='string' name='[Calculation_2701818594217986]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [당월_매출_금액] &lt;= 41000000 THEN &quot;5등급(하위25%)&quot;&#13;&#10;ELSEIF [당월_매출_금액] &lt;= 134000000 THEN &quot;4등급(25~50%)&quot;&#13;&#10;ELSEIF [당월_매출_금액] &lt;= 481000000 THEN &quot;3등급(50~75%)&quot;&#13;&#10;ELSEIF [당월_매출_금액] &lt;= 1662000000 THEN &quot;2등급(75~90%)&quot;&#13;&#10;ELSE &quot;1등급(상위10%)&quot;&#13;&#10;END' />
      </column>
      <column caption='년+분기' datatype='string' name='[Calculation_2701818606436355]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([기준_년분기_코드], 4)+ &quot;년 &quot; + RIGHT([기준_년분기_코드], 1)+&quot;분기&quot;' />
      </column>
